{
  "rules": {
    "leaderboard": {
      ".read": true,
      ".indexOn": ["score"],
      "$entryId": {
        ".write": "auth != null && (root.child('adminAccess').child(auth.uid).val() === true || (!data.exists() && newData.child('uid').val() === auth.uid))",
        ".validate": "newData.hasChildren(['name','score','date']) && newData.child('score').isNumber() && newData.child('score').val() > 0 && newData.child('name').isString() && newData.child('name').val().length >= 1 && newData.child('name').val().length <= 24"
      }
    },
    "leaderboardDaily": {
      "$date": {
        ".read": true,
        ".indexOn": ["score"],
        "$uid": {
          ".write": "auth != null && (root.child('adminAccess').child(auth.uid).val() === true || auth.uid === $uid)",
          ".validate": "newData.hasChildren(['name','score','date']) && newData.child('score').isNumber() && newData.child('score').val() > 0 && newData.child('name').isString() && newData.child('name').val().length >= 1 && newData.child('name').val().length <= 24"
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "publicProfiles": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "activityFeed": {
      "$uid": {
        ".read": "auth != null",
        "$eventId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "dailyClaims": {
      "$date": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "friends": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid)"
        }
      }
    },
    "friendRequests": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$fromUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $fromUid)"
        }
      }
    },
    "friendRequestsSent": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$toUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $toUid)"
        }
      }
    },
    "neonSpeechThreads": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "neonSpeechMemberships": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null"
      }
    },
    "neonSpeech": {
      "$threadId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "adminActions": {
      ".read": "auth != null && root.child('adminAccess').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('adminAccess').child(auth.uid).val() === true"
    },
    "adminAccess": {
      "$uid": {
        ".read": "auth != null && (root.child('adminAccess').child(auth.uid).val() === true || auth.uid === $uid)",
        ".write": "auth != null && ((root.child('adminAccess').child(auth.uid).val() === true) || (!data.exists() && auth.uid === $uid && auth.token.email_verified === true && auth.token.email === 'al116im24@ast.kevibham.org'))",
        ".validate": "newData.val() === true"
      }
    }
  }
}
